APP_NAME=project-phoenix
MONGO_URI=
MONGO_DB_NAME=
API_GATEWAY_SERVICE_CONFIG_PATH="internal/service-configs/api-gateway/service-config.json"
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=
REDIS_USER=
JWT_KEY=
FIREBASE_AUTH_KEY_PATH="internal/service-configs/api-gateway/your-firebase-auth-key.json"
RABBITMQ_USERNAME=
RABBITMQ_PASSWORD=
RABBITMQ_HOST=
RABBITMQ_PORT=
DISABLE_REDIS=true
SENTRY_DSN=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_CLOUD_NAME=
YT_DLP_BIN=
YT_DLP_COOKIES=

S3_BUCKET_NAME= 
S3_REGION=
S3_ACCESS_KEY_ID=AKI...
S3_SECRET_ACCESS_KEY=bwc...
S3_FOLDER_NAME=


# LLM API Configuration Encryption
# Must be at least 32 characters for AES-256 encryption
# Used to encrypt/decrypt stored LLM API keys
ENCRYPTION_KEY=your-secret-encryption-key-min-32-characters-long

# OpenRouter LLM Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
OPENROUTER_VISION_MODEL=anthropic/claude-3.5-sonnet

# Qdrant Vector Database Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_COLLECTION_NAME=screenshot_memories

# LLM Configuration for Cricket Commentary
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=your_api_key_here

# API Key Scraper Service Configuration
# GitHub API token for code search (comma-separated for multiple tokens)
GITHUB_API_TOKEN=ghp_your_github_token_here

# Scraper service port (default: 8888)
SCRAPER_SERVICE_PORT=8888

# Scraping interval in minutes (default: 20)
SCRAPING_INTERVAL_MINUTES=20

# Validation interval in minutes for worker-service (default: 60)
VALIDATION_INTERVAL_MINUTES=60

# Enable debug logging for API validation responses (true/false)
VERIFIER_DEBUG=false

# Worker pool size for concurrent file processing (default: 10, max: 50)
SCRAPER_WORKER_POOL_SIZE=10

# Discord Webhook URLs
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_TRACKER_WEBHOOK_URL
DISCORD_WEBHOOK_VERIFIER=https://discord.com/api/webhooks/YOUR_VERIFIER_WEBHOOK_URL

# Re-validation interval for valid keys (in minutes, default: 5)
REVALIDATION_INTERVAL_MINUTES=5
