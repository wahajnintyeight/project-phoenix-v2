{
  "version": "1.0",
  "description": "Search patterns for finding exposed API keys on GitHub and GitLab",
  "patterns": [
    {
      "provider": "OpenAI",
      "enabled": true,
      "queries": [
        {
          "pattern": "\"sk-proj-\" ",
          "description": "OpenAI project-based keys in .env files"
        },
        {
          "pattern": "\"sk-\" ",
          "description": "OpenAI keys in .env files"
        },
        {
          "pattern": "\"OPENAI_API_KEY\" ",
          "description": "OpenAI environment variable in .env files"
        },
        {
          "pattern": "\"openai.api_key\" ",
          "description": "OpenAI config in JSON files"
        },
        {
          "pattern": "\"chatgpt api key\" ",
          "description": "ChatGPT API key references"
        },
        {
          "pattern": "\"gpt-4 api key\" ",
          "description": "GPT-4 API key references"
        }
      ]
    },
    {
      "provider": "Anthropic",
      "enabled": true,
      "queries": [
        {
          "pattern": "\"sk-ant-\" ",
          "description": "Anthropic keys in .env files"
        },
        {
          "pattern": "\"ANTHROPIC_API_KEY\" ",
          "description": "Anthropic environment variable"
        },
        {
          "pattern": "\"anthropic_api_key\" ",
          "description": "Anthropic lowercase variant"
        },
        {
          "pattern": "\"claude api key\" ",
          "description": "Claude API key references"
        }
      ]
    },
    {
      "provider": "Google",
      "enabled": true,
      "queries": [
        {
          "pattern": "\"AIza\" ",
          "description": "Google API keys in .env files"
        },
        {
          "pattern": "\"GOOGLE_API_KEY\" ",
          "description": "Google environment variable"
        },
        {
          "pattern": "\"gemini_api_key\" ",
          "description": "Gemini-specific API key"
        }
      ]
    },
    {
      "provider": "OpenRouter",
      "enabled": true,
      "queries": [
        {
          "pattern": "\"sk-or-\" ",
          "description": "OpenRouter keys in .env files"
        },
        {
          "pattern": "\"OPENROUTER_API_KEY\" ",
          "description": "OpenRouter environment variable"
        },
        {
          "pattern": "\"openrouter_api_key\" ",
          "description": "OpenRouter lowercase variant"
        },
        {
          "pattern": "\"openrouter api key\" ",
          "description": "OpenRouter natural language reference"
        }
      ]
    },
    {
      "provider": "Moonshot",
      "enabled": true,
      "queries":[
        {
          "pattern": "\"sk-\" ",
          "description": "Moonshot keys"
        }
      ]
    },
    {
      "provider": "HuggingFace",
      "enabled": true,
      "queries": [
        {
          "pattern": "\"hf_\" ",
          "description": "Hugging Face user access tokens in code or .env"
        },
        {
          "pattern": "\"HUGGING_FACE_HUB_TOKEN\" ",
          "description": "Hugging Face hub token environment variable"
        },
        {
          "pattern": "\"HF_TOKEN\" ",
          "description": "HF_TOKEN shorthand"
        },
        {
          "pattern": "\"api_org_\" ",
          "description": "Hugging Face organization API tokens"
        }
      ]
    },
    {
      "provider": "Other",
      "enabled": true,
      "queries": [
        {
          "pattern": "\"r8_\" ",
          "description": "Replicate API keys"
        },
        {
          "pattern": "\"fw_\" ",
          "description": "Fireworks AI keys"
        },
        {
          "pattern": "\"API_KEY\" ",
          "description": "Generic API key variable - verifier will determine provider"
        },
        {
          "pattern": "\"_KEY\" ",
          "description": "Generic key variable - verifier will determine provider"
        }
      ]
    }
  ],
  "notes": [
    "GitHub search syntax: https://docs.github.com/en/search-github/searching-on-github/searching-code",
    "Use 'extension:' to target specific file types (env, json, yaml, config)",
    "Use quotes for exact matches",
    "Combine multiple terms with spaces for AND logic",
    "Set 'enabled: false' to disable a provider's queries without deleting them",
    "Generic patterns in 'Other' category will be validated against all providers by the verifier service"
  ]
}
